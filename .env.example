# Database
DATABASE_URL=postgresql+psycopg://teencode:teencode_secret@localhost:5434/teencode_db

# LLM Proxy (từ INTEGRATION.md)
LLM_BASE_URL=http://localhost:9000
LLM_API_KEY=your-proxy-api-key-here
LLM_MODEL=claude-sonnet-4.6

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# API
BACKEND_PORT=8001
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
MAX_INPUT_LENGTH=300

# Admin (default - ĐỔI NGAY SAU KHI DEPLOY!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
ADMIN_ALLOWED_IPS=139.60.163.130,127.0.0.1
TRUSTED_PROXY_IPS=
ADMIN_OTP_EXPIRE_MINUTES=5
